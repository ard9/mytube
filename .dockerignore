# Keep the build context small and don't bake local state into the image.
**/__pycache__/
**/*.pyc
.git/
.gitignore

# Local app state (these belong in the /data volume, not the image)
config.json
notes.json
watch_state.json
dictionary.json
srs_history.json
tts_library.json
tts_voices.json
conversation_data/
dict_media/
tts_media/
tts_voices/

# Local video library and model caches must never be copied in
library/
*.wav
*.mp4
*.mkv
*.webm

# Editor / OS noise
.vscode/
.idea/
.DS_Store
Thumbs.db
